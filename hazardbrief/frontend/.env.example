# HazardBrief フロントエンド 環境変数
# このファイルをコピーして .env.local を作成し、実際の値を設定してください
# cp .env.example .env.local

# API ベース URL
# ローカル開発時は FastAPI 直接 (uvicorn :8000)
# 本番は API Gateway の URL (末尾スラッシュなし)
VITE_API_BASE=http://localhost:8000

# Auth0 設定 (Auth0 ダッシュボードから取得)
# https://manage.auth0.com → Applications → <your app> → Settings
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=https://your-audience
VITE_AUTH0_REDIRECT_URI=http://localhost:5173
