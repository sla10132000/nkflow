# 本番環境: CloudFront の API Lambda Function URL
# 例: https://xxxxxx.lambda-url.ap-northeast-1.on.aws
VITE_API_BASE=

# Vue Router のベースパス (カスタムドメイン使用時は /)
# カスタムドメイン (nkflow.senken.app): /
# 開発 (localhost): / またはコメントアウト
VITE_ROUTER_BASE=

# Auth0 設定 (Google ソーシャルログイン)
# Auth0 ダッシュボード > Applications > App > Settings から取得
VITE_AUTH0_DOMAIN=dev-0ay7xweu5xq7tmq2.us.auth0.com
VITE_AUTH0_CLIENT_ID=wBpgIGTDeBKZ8siQh9zqpRstjwKzhT2G

# Auth0 API Audience
# Auth0 ダッシュボード > Applications > APIs で作成した API の Identifier を設定
# 例: https://nkflow.example.com/api
VITE_AUTH0_AUDIENCE=
